# Enables the AI assistant and /api/ai/suggest. Without this, the UI shows a
# helpful "not configured" banner (users can add their own key in Settings).
ANTHROPIC_API_KEY=

# JWT signing secret — change to a random 64-char string in production
JWT_SECRET=helios-dev-secret-change-in-production

# AES-256 key for encrypting user API keys at rest — change in production
ENCRYPTION_KEY=helios-dev-enc-key-change-in-production
