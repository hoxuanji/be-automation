# Enables the AI assistant and /api/ai/suggest. Without this, the UI shows a
# helpful "not configured" banner (users can add their own key in Settings).
ANTHROPIC_API_KEY=

# JWT signing secret — change to a random 64-char string in production
JWT_SECRET=helios-dev-secret-change-in-production

# AES-256 key for encrypting user API keys at rest — change in production
ENCRYPTION_KEY=helios-dev-enc-key-change-in-production

# Optional: Resend API key for sending real password reset emails.
# Without this, reset links are logged to the server console (fine for dev).
# Get one at https://resend.com — free tier covers 3,000 emails/month.
RESEND_API_KEY=

# Optional: From address for transactional emails (requires RESEND_API_KEY)
EMAIL_FROM=noreply@yourdomain.com

# Optional: GitHub OAuth app credentials for "Continue with GitHub"
# Create at https://github.com/settings/apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
